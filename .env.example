# LLM provider: cursor | ollama | openai
LLM_PROVIDER=cursor

# --- Cursor SDK (Gravity OS pattern — telegram weekly review) ---
# Key from https://cursor.com/dashboard/cloud-agents (no quotes in .env)
CURSOR_API_KEY=
CURSOR_MODEL_ID=composer-2

# --- Brethren Ollama homelab (when LLM_PROVIDER=ollama) ---
# Gravity OS: Brethren hosts Ollama; reach it via Tailscale MagicDNS from Tzeentch.
# Ref: graVityOS-Project/graVityOS/AI and Automation/Multi-Computer AI Homelab.md
# Hostname only (not a full URL). Or set OPENAI_BASE_URL instead.
OLLAMA_HOST=brethren

# Same model as Gravity OS Obsidian Copilot (qwen3:8b, 16 GB VRAM on Brethren)
LLM_MODEL=qwen3:8b
OPENAI_API_KEY=ollama

# --- Local Ollama on this machine (uncomment instead) ---
# OLLAMA_HOST=localhost
# OPENAI_BASE_URL=http://localhost:11434/v1
# LLM_MODEL=qwen3:8b

# --- Hosted API fallback ---
# LLM_PROVIDER=openai
# OPENAI_API_KEY=sk-...
# LLM_MODEL=gpt-4o-mini

# Embeddings for FAISS index build (runs on dev machine; sentence-transformers local)
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# Personal Fitbod + Apple Health (never commit raw data)
# GRAVITYOS_DATA_DIR=C:\Users\rhdam\graVityOS-Project\graVityOS\Data

# Optional tracing
# LANGSMITH_API_KEY=
# LANGSMITH_PROJECT=lifting-coach-agent

# API (Milestone 5)
API_HOST=0.0.0.0
API_PORT=8000
