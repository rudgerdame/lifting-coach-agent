# LLM provider: ollama | openai
LLM_PROVIDER=ollama

# OpenAI-compatible endpoint (Ollama default: http://localhost:11434/v1)
OPENAI_BASE_URL=http://localhost:11434/v1
OPENAI_API_KEY=ollama
OPENAI_MODEL=llama3.2:3b

# Embeddings (local HuggingFace model name)
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# Optional: local Gravity OS data (never commit this path's contents)
# GRAVITYOS_DATA_DIR=C:\Users\rhdam\graVityOS-Project\graVityOS\Data

# Optional tracing
# LANGSMITH_API_KEY=
# LANGSMITH_PROJECT=lifting-coach-agent

# API
API_HOST=0.0.0.0
API_PORT=8000
